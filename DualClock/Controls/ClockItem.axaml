<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="DualClock.Controls.ClockItem"
             x:Name="RootControl"
             Width="100"
             Height="60">

    <UserControl.Resources>
        <LinearGradientBrush x:Key="DefaultGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#333333" Offset="0"/>
            <GradientStop Color="#333333" Offset="0.5"/>
            <GradientStop Color="#4FACFE" Offset="1"/>
        </LinearGradientBrush>
    </UserControl.Resources>

    <Border Background="#333333"
            CornerRadius="4"
            Padding="0">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock x:Name="PART_DateTextBlock"
                       Text="Beijing 06/22"  
                       FontSize="14"
                       FontWeight="Bold"
                       Foreground="#CCCCCC"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,0" />

            <Border x:Name="PART_TimeBorder"
                    CornerRadius="4"
                    Margin="0,5,0,0"
                    Padding="6,4"
                    Background="{Binding TimeBackground,   ElementName=RootControl}"
                    >
                <TextBlock x:Name="PART_TimeTextBlock"
                           Text="23:53"   
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="Black"
                           HorizontalAlignment="Center" />
            </Border>

        </StackPanel>
    </Border>
</UserControl>