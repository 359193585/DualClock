<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="DualClock.Controls.AnalogClock"
             x:Name="Root"
             Width="200"
             Height="200">
    <Canvas x:Name="ClockCanvas">
        <!-- БэХЬБГОАЃЌГпДчдкКѓЬЈЭЈЙ§ SizeChanged ПижЦ -->
        <Ellipse x:Name="FaceEllipse"
                 Stroke="Black" StrokeThickness="2"/>

        <!-- ЪБеы -->
<Path x:Name="HourHand" Stroke="Black" StrokeThickness="5" StrokeLineCap="Round">
    <Path.Data>
        <LineGeometry StartPoint="0,0" EndPoint="0,-40" />
    </Path.Data>
    <Path.RenderTransform>
        <RotateTransform Angle="0" CenterX="0" CenterY="0" />
    </Path.RenderTransform>
</Path>

<!-- Зжеы -->
<Path x:Name="MinuteHand" Stroke="Black" StrokeThickness="3" StrokeLineCap="Round">
    <Path.Data>
        <LineGeometry StartPoint="0,0" EndPoint="0,-60" />
    </Path.Data>
    <Path.RenderTransform>
        <RotateTransform Angle="0" CenterX="0" CenterY="0" />
    </Path.RenderTransform>
</Path>

<!-- Уыеы -->
<Path x:Name="SecondHand" Stroke="Red" StrokeThickness="1.5" StrokeLineCap="Round">
    <Path.Data>
        <LineGeometry StartPoint="0,0" EndPoint="0,-65" />
    </Path.Data>
    <Path.RenderTransform>
        <RotateTransform Angle="0" CenterX="0" CenterY="0" />
    </Path.RenderTransform>
</Path>

        <!-- жааФЕу -->
        <Ellipse x:Name="CenterDot" Width="8" Height="8" Fill="Black" />

        <!-- ШеЦкЮФБО -->
        <TextBlock x:Name="DateText" Foreground="Black" FontSize="12" FontWeight="Bold" />
    </Canvas>
</UserControl>