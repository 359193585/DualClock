<local:BaseWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:DualClock"
        x:Class="DualClock.MainWindow"
        x:DataType="local:MainWindow"
        Title="Dual Clock"
        WindowState="FullScreen"
        Background="Black"
        Topmost="True" 
        >

    <Grid RowDefinitions="3*, 1.6*, 3*, 1.6*, 1.8*, 70" Margin="30" Background="Black">
       
        <Grid Grid.Row="0" ColumnDefinitions="2*,3*" Background="Black">

             <Viewbox Grid.Column="0"  Stretch="Fill" Margin="20,5">
                <TextBlock Text="{Binding SfCityDisplay}" 
                       Foreground="LightGreen" 
                       FontFamily="Courier New, Arial, Microsoft YaHei, DejaVu Sans"
                       FontSize="80"
                       TextAlignment="Right"
                       FontWeight="Bold"
                       HorizontalAlignment="Center" 
                       VerticalAlignment="Center"/>
             </Viewbox>
            <Viewbox Grid.Column="1"  Stretch="Fill" Margin="20,5">
                <TextBlock Text="{Binding SfTimeDisplay}" 
                       Foreground="LightGreen" 
                       FontFamily="Courier New, Arial, Microsoft YaHei, DejaVu Sans"
                       FontSize="100" 
                       TextAlignment="Right"
                       FontWeight="Bold"
                       HorizontalAlignment="Center" 
                       VerticalAlignment="Center"/>
            </Viewbox>
        </Grid>

        <TextBlock Grid.Row="1" 
                   Text="{Binding SfDateDisplay}" 
                   Foreground="LightCyan" 
                   FontFamily="Arial, Microsoft YaHei, DejaVu Sans"
                   FontSize="80" 
                   FontWeight="SemiBold"
                   HorizontalAlignment="Center" 
                   VerticalAlignment="Center"
                   />

         <Grid Grid.Row="2" ColumnDefinitions="2*,3*" Background="Black">

            <Viewbox Grid.Column="0" Stretch="Fill" Margin="20,5">
                <TextBlock Text="{Binding BjCityDisplay}" 
                           Foreground="LightGreen" 
                           FontFamily="Courier New, Arial, Microsoft YaHei, DejaVu Sans" 
                           FontSize="80"
                           TextAlignment="Right"
                           FontWeight="Bold"/>
            </Viewbox>
            <Viewbox Grid.Column="1" Stretch="Fill" Margin="20,5">
                <TextBlock Text="{Binding BjTimeDisplay}" 
                           Foreground="LightGreen" 
                           FontFamily="Courier New, Arial, Microsoft YaHei, DejaVu Sans" 
                           FontSize="100" 
                           TextAlignment="Right"
                           FontWeight="Bold"/>
            </Viewbox>
        </Grid>

        <TextBlock Grid.Row="3" Text="{Binding BjDateDisplay}" 
                   Foreground="LightYellow" 
                   FontFamily="Arial, Microsoft YaHei, DejaVu Sans"
                   FontSize="80" 
                   TextAlignment="Right"
                   FontWeight="SemiBold"
                   HorizontalAlignment="Center" 
                   VerticalAlignment="Center"/>


        <TextBlock Grid.Row="4" Text="{Binding LocalTimeDisplay}" 
                   Foreground="Red" 
                   FontFamily="Arial, Microsoft YaHei, DejaVu Sans"
                   FontWeight="Bold"
                   FontSize="85" 
                   HorizontalAlignment="Center" 
                   VerticalAlignment="Center"/>

        <TextBlock Grid.Row="5" Text="[ 按 F 全屏，T 置顶小窗， A 表盘，ESC 退出，右键单击显示菜单 ]" 
                   Foreground="DimGray" 
                   FontFamily="Arial, Microsoft YaHei, DejaVu Sans"
                   FontSize="22" 
                   HorizontalAlignment="Center" 
                   VerticalAlignment="Bottom"/>
        
    </Grid>
</local:BaseWindow>
