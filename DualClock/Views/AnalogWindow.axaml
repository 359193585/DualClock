<local:BaseWindow  xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="300"
        xmlns:local="using:DualClock"
        xmlns:controls="using:DualClock.Controls"
        x:Class="DualClock.AnalogWindow"
        x:DataType="local:AnalogWindow"
        Title="AnalogClock"
        Width="300"
        Height="300"
        CanResize="False"
        WindowDecorations="None"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        >

    <StackPanel Margin="0" HorizontalAlignment="Center" VerticalAlignment="Center">


        <controls:AnalogClockPlus  x:Name="AnalogClockControl"
                          Time="{Binding CurrentTime}"
                          Width="300"
                          Height="300"
                          ShowHourNumbers="True"
                          ShowMinuteTicks="True"
                          DateFormat="MonthDayWeek"
                          BackgroundBrush="LightBlue"
                          TickColor="DarkBlue"
                          TickThickness="4"
                          MinuteTickColor="Gray"
                          MinuteTickThickness="2"
                          DateTextColor="Black"
                          DateFontSize="16"
                          />

    </StackPanel>
</local:BaseWindow >
