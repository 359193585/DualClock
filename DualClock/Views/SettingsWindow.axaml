<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:DualClock"
        xmlns:modules="using:DualClock.Modules"
        x:Class="DualClock.SettingsWindow"
        x:DataType="local:SettingsWindow"
        Title="时区设置" 
        Width="400" Height="450"
        WindowStartupLocation="CenterOwner"
        Background="#222222">
    
    <Window.Styles>
        <Style Selector="Button:pointerover /template/ ContentPresenter">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#555555" /> </Style>
    </Window.Styles>

    <StackPanel Margin="20" Spacing="15">
        <TextBlock Text="选择时区 1 (上方显示):" Foreground="White"/>

        <ComboBox Name="ComboZone1" 
                  ItemsSource="{x:Static modules:ClockConfig.AllZones}" 
                  HorizontalAlignment="Stretch" Foreground="White">
            <ComboBox.ItemTemplate>
                <DataTemplate x:DataType="modules:TimeZoneItem">
                    <TextBlock Text="{Binding DisplayName}" />
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>

        <TextBlock Text="选择时区 2 (下方显示):" Foreground="White" Margin="0,10,0,0"/>

        <ComboBox Name="ComboZone2" 
                  ItemsSource="{x:Static modules:ClockConfig.AllZones}" 
                  HorizontalAlignment="Stretch" Foreground="White">
            <ComboBox.ItemTemplate>
                <DataTemplate x:DataType="modules:TimeZoneItem">
                    <TextBlock Text="{Binding DisplayName}" />
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>

         <!-- 程序设置区域 ===== -->
        <TextBlock Text="启动设置" Foreground="White" FontWeight="Bold" Margin="0,10,0,0"/>
        
        <StackPanel Orientation="Horizontal" Spacing="10">
            <TextBlock Text="启动窗口:" Foreground="White" VerticalAlignment="Center"/>
            <ComboBox Name="ComboStartWindow" 
                      Width="120" 
                      Foreground="White">
                <ComboBoxItem>主窗口</ComboBoxItem>
                <ComboBoxItem>小窗</ComboBoxItem>
            </ComboBox>
        </StackPanel>

        <CheckBox Name="CheckAutoStart" 
                  Content="开机自动启动" 
                  Foreground="White" 
                  Margin="0,5,0,0"/>


       <Button Content="保存设置" 
        HorizontalAlignment="Right" 
        Width="100" 
        Margin="0,20,0,0" 
        Foreground="White" 
        Background="#444444"
        HorizontalContentAlignment="Center"
        VerticalContentAlignment="Center"
        Click="OnSaveClick"/>
    </StackPanel>
</Window>