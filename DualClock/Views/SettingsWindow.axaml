<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:DualClock"
        xmlns:modules="using:DualClock.Modules"
        x:Class="DualClock.SettingsWindow"
        x:DataType="local:SettingsWindow"
        Title="时区设置" 
        Width="480" 
        MinHeight="400"
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        Background="#222222">
    
    <Window.Styles>
        <Style Selector="Button:pointerover /template/ ContentPresenter">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#555555" />
        </Style>
        <Style Selector="CheckBox:pointerover /template/ ContentPresenter">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#555555" />
        </Style>
    </Window.Styles>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20" Spacing="10">
            
            <!-- 时区列表标题 -->
            <TextBlock Text="时区列表（显示顺序从上到下）" Foreground="White" FontWeight="Bold" Margin="0,0,0,5"/>

            <!-- 动态时区列表 -->
            <ItemsControl x:Name="ZonesItemsControl" 
                          ItemsSource="{Binding ZonesCollection}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="local:ZoneEntry">
                        <Border BorderBrush="#444444" BorderThickness="0,0,0,1" Padding="0,5">
                            <Grid ColumnDefinitions="*, Auto">
                                <!-- 时区下拉选择 -->
                                <ComboBox Grid.Column="0"
                                          ItemsSource="{x:Static modules:ClockConfig.AllZones}"
                                          SelectedItem="{Binding SelectedZone, Mode=TwoWay}"
                                          HorizontalAlignment="Stretch"
                                          Foreground="White">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="modules:TimeZoneItem">
                                            <TextBlock Text="{Binding DisplayName}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <!-- 删除按钮 -->
                               <Button Grid.Column="1"
                                            Content="✕"
                                            Width="30"
                                            Height="30"
                                            Margin="10,0,0,0"
                                            Foreground="White"
                                            Background="#CC3333"
                                            HorizontalContentAlignment="Center"
                                            VerticalContentAlignment="Center"
                                            Click="OnRemoveZoneClick" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- 添加时区按钮 -->
            <Button Content="＋ 添加时区"
                    HorizontalAlignment="Left"
                    Margin="0,5,0,10"
                    Foreground="White"
                    Background="#444444"
                    Click="OnAddZoneClick" />

            <!-- 分隔线 -->
            <Rectangle Height="1" Fill="#444444" Margin="0,5,0,5" />

            <!-- 程序设置区域 -->
            <TextBlock Text="启动设置" Foreground="White" FontWeight="Bold" Margin="0,5,0,0"/>
            
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="启动窗口:" Foreground="White" VerticalAlignment="Center"/>
                <ComboBox Name="ComboStartWindow" 
                          Width="120" 
                          Foreground="White">
                    <ComboBoxItem>主窗口</ComboBoxItem>
                    <ComboBoxItem>小窗</ComboBoxItem>
                </ComboBox>
            </StackPanel>

            <CheckBox Name="CheckAutoStart" 
                      Content="开机启动" 
                      Foreground="White" 
                      Background="#444444"
                      Margin="0,5,0,0"/>

            <CheckBox Name="CheckShowSeconds" 
                      Content="显示秒数" 
                      Foreground="White" 
                      Background="#444444"
                      Margin="0,5,0,0"/>

            <Button Content="保存设置" 
                    HorizontalAlignment="Right" 
                    Width="100" 
                    Margin="0,20,0,0" 
                    Foreground="White" 
                    Background="#444444"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Click="OnSaveClick"/>
        </StackPanel>
    </ScrollViewer>
</Window>