<local:BaseWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="330" d:DesignHeight="60"
        xmlns:local="using:DualClock"
        xmlns:controls="using:DualClock.Controls"
        x:Class="DualClock.TinyWindow"
        Title="TinyWindow"
        CanResize="False"   
        Width="330" 
        Height="60"
        WindowDecorations="None"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        >

     <Window.Resources>
        <LinearGradientBrush x:Key="Grad1" EndPoint="1,0">
            <GradientStop Color="#FF416C" Offset="0"/>
            <GradientStop Color="#FF4B2B" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="Grad2" EndPoint="1,0">
            <GradientStop Color="#00B4DB" Offset="0"/>
            <GradientStop Color="#0083B0" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="Grad3" EndPoint="1,0">
            <GradientStop Color="#11998E" Offset="0"/>
            <GradientStop Color="#38EF7D" Offset="1"/>
        </LinearGradientBrush>
    </Window.Resources>


 <StackPanel x:Name="TinyWrapPanel"
               Orientation="Horizontal"
               Margin="0"
               HorizontalAlignment="Center"
               VerticalAlignment="Center">

    </StackPanel>
</local:BaseWindow>
